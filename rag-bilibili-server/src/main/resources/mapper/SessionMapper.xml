<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.ragbilibili.mapper.SessionMapper">

    <resultMap id="BaseResultMap" type="com.example.ragbilibili.entity.Session">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="session_type" property="sessionType"/>
        <result column="video_id" property="videoId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <resultMap id="SessionWithVideoTitleResultMap" type="com.example.ragbilibili.entity.SessionWithVideoTitle">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="session_type" property="sessionType"/>
        <result column="video_id" property="videoId"/>
        <result column="create_time" property="createTime"/>
        <result column="video_title" property="videoTitle"/>
    </resultMap>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT id, user_id, session_type, video_id, create_time
        FROM session
        WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT id, user_id, session_type, video_id, create_time
        FROM session
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <select id="selectWithVideoTitleByUserId" resultMap="SessionWithVideoTitleResultMap">
        SELECT s.id,
               s.user_id,
               s.session_type,
               s.video_id,
               s.create_time,
               v.title AS video_title
        FROM session s
        LEFT JOIN video v ON s.video_id = v.id
        WHERE s.user_id = #{userId}
        ORDER BY s.create_time DESC
    </select>

    <select id="selectIdsByVideoId" resultType="long">
        SELECT id
        FROM session
        WHERE video_id = #{videoId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO session (user_id, session_type, video_id, create_time)
        VALUES (#{userId}, #{sessionType}, #{videoId}, #{createTime})
    </insert>

    <delete id="deleteById">
        DELETE FROM session WHERE id = #{id}
    </delete>

    <delete id="deleteByVideoId">
        DELETE FROM session WHERE video_id = #{videoId}
    </delete>

</mapper>
